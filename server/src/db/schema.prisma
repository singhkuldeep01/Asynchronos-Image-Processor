generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model image {
  id            String      @id @default(cuid())
  originalName  String
  mimeType      String
  size          BigInt
  originalPath  String
  thumbnailPath String?
  mediumPath    String?
  largePath     String?
  webpPath      String?
  avifPath      String?
  status        image_status @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum image_status {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
